<!doctype html>
<html>

<head>
  <meta charset="utf-8">
  <title>Blockchain Certificates</title>
  <base href="/">
  <style>
    html {
      font-size: 20px;
    }
  </style>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.1.0/css/bootstrap.min.css" integrity="sha384-9gVQ4dYFwwWSjIDZnLEWnxCjeSWFphJiwGPXr1jddIhOegiu1FwO5qRGvFXOdJZ4" crossorigin="anonymous">
  <link rel="stylesheet" href="stylesheets/style.css">
</head>


<body>
 <%- include('partials/navbar-partial.ejs') %>
<div class="hero">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-6">
        <h1 class="hero-title">Academic Certificates, Verified Globally</h1>
        <p class="hero-subtitle">Issue, store, and verify certificates with cryptographic proofs on a transparent ledger.</p>
        <div class="hero-actions">
          <a class="btn btn-primary btn-lg" href="/certificates" role="button">Browse Issued Certificates</a>
          <a class="btn btn-outline-success btn-lg" href="/verify" role="button">Verify Proof</a>
        </div>
      </div>
      <div class="col-lg-6 text-center">
        <img class="hero-image" src="/images/blockchain-diagram.svg" alt="Blockchain technology diagram">
      </div>
    </div>
  </div>
</div>

<div id="jumbotron-index" class="container marketing">
  <div class="row">
    <div class="col-lg-4 text-center action-card">
      <div class="action-icon">
        <svg width="42" height="42" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="#18a957" d="M12 12c2.76 0 5-2.24 5-5S14.76 2 12 2 7 4.24 7 7s2.24 5 5 5zm0 2c-4.33 0-8 2.17-8 5v3h16v-3c0-2.83-3.67-5-8-5z"/>
        </svg>
      </div>
      <h2>Students</h2>
      <p>Manage certificates, share proofs, and download your documents.</p>
      <div class="action-buttons">
        <a class="btn btn-primary" href="/student/login" role="button">Sign In</a>
        <a class="btn btn-outline-success" href="/student/register" role="button">Register</a>
      </div>
    </div>
    <div class="col-lg-4 text-center action-card">
      <div class="action-icon">
        <svg width="42" height="42" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="#18a957" d="M12 3L2 8l10 5 10-5-10-5zm0 7l-8-4v9l8 4 8-4V6l-8 4zm-4 7.2l4 2 4-2v-2.4l-4 2-4-2v2.4z"/>
        </svg>
      </div>
      <h2>Universities</h2>
      <p>Issue official certificates and upload the documents.</p>
      <div class="action-buttons">
        <a class="btn btn-primary" href="/university/login" role="button">Sign In</a>
        <a class="btn btn-outline-success" href="/university/register" role="button">Register</a>
      </div>
    </div>
    <div class="col-lg-4 text-center action-card">
      <div class="action-icon">
        <svg width="42" height="42" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="#18a957" d="M9 3h6l1 2h5v2H3V5h5l1-2zm-3 6h12l-1 12H7L6 9zm5 2v8h2v-8h-2z"/>
        </svg>
      </div>
      <h2>Verify</h2>
      <p>View issued certificates without signing in.</p>
      <div class="action-buttons">
        <a class="btn btn-primary" href="/certificates" role="button">View Issued</a>
      </div>
    </div>
  </div>
</div>



</body>

</html>

<script src="https://code.jquery.com/jquery-3.3.1.slim.min.js" integrity="sha384-q8i/X+965DzO0rT7abK41JStQIAqVgRVzpbzo5smXKp4YfRvH+8abtTE1Pi6jizo" crossorigin="anonymous"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.14.0/umd/popper.min.js" integrity="sha384-cs/chFZiN24E4KMATLdqdvsezGxaGsi4hLGOzlXwp5UZB1LY//20VyM2taTB4QvJ" crossorigin="anonymous"></script>
<script src="https://stackpath.bootstrapcdn.com/bootstrap/4.1.0/js/bootstrap.min.js" integrity="sha384-uefMccjFJAIv6A+rW+L4AHf99KvxDjWSu1z9VI8SKNVmz4sk7buKt/6v9KI65qnm" crossorigin="anonymous"></script>
